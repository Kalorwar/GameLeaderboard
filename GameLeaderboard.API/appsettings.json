{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=game_leaderboard_db;Username=postgres;Password=postgres;",
    "Redis": "localhost:6379"
  },
  "Jwt": {
    "SecretKey": "SuperSecretKeyForGameLeaderboardWhichNeedsToBeLongEnough",
    "Issuer": "GameLeaderboardAPI",
    "Audience": "GameLeaderboardClients"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}